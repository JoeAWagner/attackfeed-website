# Neon Postgres connection string
# Get yours free at https://neon.tech
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Secret key to protect the cron endpoint from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET=your-secret-key-here

# Your Vercel deployment URL (for GitHub Actions to call the cron endpoint)
NEXT_PUBLIC_SITE_URL=https://www.attackfeed.com

# --- Google integrations (all optional; features activate when set) ---

# Google Analytics 4 measurement id (Admin -> Data streams -> Web)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console HTML-tag verification token (content="..." value)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense publisher id (enables the ad script + /ads.txt)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# AdSense ad-unit slot id for the sidebar unit
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
