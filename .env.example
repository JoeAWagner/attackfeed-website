# Neon Postgres connection string
# Get yours free at https://neon.tech
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Secret key to protect the cron endpoint from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET=your-secret-key-here

# Your Vercel deployment URL (for GitHub Actions to call the cron endpoint)
NEXT_PUBLIC_SITE_URL=https://www.attackfeed.com
